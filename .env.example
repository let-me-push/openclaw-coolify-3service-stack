# Core
TZ=Europe/Berlin
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_TOKEN=change-me-very-long-random-token
OPENCLAW_CONTROL_UI_ORIGIN=https://openclaw.example.com

# Browser service + OpenClaw remote CDP profile
BROWSER_TOKEN=change-me-browser-token
BROWSER_CONCURRENT=5
BROWSER_QUEUED=10
BROWSER_TIMEOUT_MS=120000

# code-server
CODE_SERVER_PORT=8443
CODE_SERVER_PASSWORD=change-me-code-server-password
CODE_SERVER_SUDO_PASSWORD=
PUID=1000
PGID=1000

# Telegram admin (single user who controls this stack)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# Optional model/provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
